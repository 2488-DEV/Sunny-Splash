--- !u!114 &116119760
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 116119759}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb55f909ae9bd1c448c0ad57e6c63e39, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  speakerName: Maple
  sentences:
  - "\"Ouch! The ground here is scorching! Be careful\u2014if we walk on these Orange
    Areas, \nmy Heat Bar will skyrocket much faster than usual!\""
  - "\"Aha! But we have a trick up our sleeve. Look! If we stay under the Cloud Shadows,
    \nthe sun can't reach me, and the heat won't rise at all. It's so cool and comfy!"
  - "\"Make sure to use the shadows to save our energy! Alright... stay strong, \nMaple!
    Quack Quack!\""
  dialogueManager: {fileID: 316937212}
