  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb55f909ae9bd1c448c0ad57e6c63e39, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  speakerName: Maple
  sentences:
  - "\"Wow! Quick, take me for a dip! It\u2019ll cool me down, \nand I can refill
    the water in my backpack too"
  - '"Once the pack is full, stand near a withered tree and press Spacebar to splash
    it out. Splashhh!~"'
  - "\"Let\u2019s see if this bucket of water can bring the greenery back to life...
    I\u2019m counting on you! Quack! Quack!\""
  dialogueManager: {fileID: 316937212}
