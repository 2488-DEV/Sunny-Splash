  typingSound: {fileID: 8300000, guid: 9a528bfd71db2384ea5c2792f27912a5, type: 3}
  nextClickSound: {fileID: 8300000, guid: 75f50069af224154a9e20950156b65d1, type: 3}
  sentences:
  - "\"Quack Quack! Hello there~ My name is 'Maple.' I'm the little duck who takes
    care of this forest. It\u2019s so nice to meet you!"
  - "\"Oh no... look at that! The sun is so scorching that our lush green forest
    has turned all brown and dry. Let\u2019s work together to Refresh this place
    and bring the greenery back, shall we?\""
  - "\"Eek! But be careful\u2014it\u2019s super hot out here! Every time I walk in
    the sun or do some work, my 'Overheat Bar' will start rising really fast!"
  - "\"If you want to move faster, just hold down the Shift key to run! But keep
    an eye on my 'Stamina Gauge'\u2014if it runs out, I\u2019ll be too tired to run
    and will need a little break to catch my breath."
  - "\"Alright! Use the W A S D keys to guide me around the forest. I\u2019m ready
    to go! Quack Quack!"
  typingSpeed: 0.04
  playOnStart: 1
